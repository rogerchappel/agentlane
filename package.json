{
  "name": "agentlane",
  "version": "0.1.0",
  "description": "Local-first TypeScript CLI that plans safe parallel work lanes for AI coding agents.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentlane": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "SAFETY.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/**/*.test.js",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "prepack": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/agentlane.git"
  },
  "keywords": [
    "agents",
    "cli",
    "planning",
    "typescript",
    "local-first"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/rogerchappel/agentlane/issues"
  },
  "homepage": "https://github.com/rogerchappel/agentlane#readme",
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^24.9.1"
  }
}
